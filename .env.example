# ============================================================
# Beit Midrash Finance — Environment Variables
# Generated by scripts/setup.sh — DO NOT edit manually
# ============================================================

# PostgreSQL
POSTGRES_PASSWORD=your-secure-password-here

# JWT Secret (used by PostgREST to validate tokens)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# Supabase-compatible keys (JWTs signed with JWT_SECRET)
ANON_KEY=generated-anon-jwt
SERVICE_ROLE_KEY=generated-service-role-jwt

# App config
NEXT_PUBLIC_SUPABASE_URL=http://gateway:8000
SUPABASE_SERVICE_ROLE_KEY=generated-service-role-jwt
